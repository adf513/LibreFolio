{"nodes": [{"id": "high_level_plan_v1_open_questions_document", "label": "Verifica mirata \u2014 share, transito, split, short e banner FIFO", "file_type": "document", "source_file": "corpus/roadmap/fifo-engine/high-level-plan_v1-open-questions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "high_level_plan_v1_open_questions_absolute_projection", "label": "Absolute Engine + User Projection", "file_type": "rationale", "source_file": "corpus/roadmap/fifo-engine/high-level-plan_v1-open-questions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Apply share_percentage only as a final per-user projection, using lot-origin ownership, to prevent transfer-induced quantity/cost distortions and keep lot identity/cache stable across users."}, {"id": "high_level_plan_v1_open_questions_transit_interval", "label": "Transit Interval [min,max)", "file_type": "rationale", "source_file": "corpus/roadmap/fifo-engine/high-level-plan_v1-open-questions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Count transfer value from departure day until the day before arrival so in-transit value no longer disappears on the departure date and the FIFO fragment timeline matches reconciliation expectations."}, {"id": "high_level_plan_v1_open_questions_split_cost_preservation", "label": "Split Cost Preservation", "file_type": "rationale", "source_file": "corpus/roadmap/fifo-engine/high-level-plan_v1-open-questions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Splits and reverse splits must preserve total cost while adjusting quantity and unit cost; current auto/WAC flows can double or halve cost incorrectly if cost_basis_override is not controlled."}, {"id": "high_level_plan_v1_open_questions_long_only_v1", "label"