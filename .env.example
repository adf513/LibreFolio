# =============================================================================
# LibreFolio Configuration
# =============================================================================

# =============================================================================
# Production Server
# =============================================================================
PORT=8000
LIBREFOLIO_DATA_DIR=./backend/data/prod
# Data is stored in: <LIBREFOLIO_DATA_DIR>/sqlite/app.db, custom-uploads/, broker_reports/, logs/
# If you want a different location (e.g. Docker volume), change the path above.

# =============================================================================
# Test Server (used by ./dev.py server --test and automated tests)
# =============================================================================
TEST_PORT=8001
# Test mode is activated via: ./dev.py server --test (sets LIBREFOLIO_TEST_MODE=1)
# In test mode, data directory is ALWAYS backend/data/test/ (ignores LIBREFOLIO_DATA_DIR)

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Portfolio
# =============================================================================
PORTFOLIO_BASE_CURRENCY=EUR

# =============================================================================
# Image Preview Cache
# =============================================================================
# Max size in MB for in-memory image preview cache (per-process, default: 50)
PREVIEW_CACHE_MAX_MB=50

# =============================================================================
# CORS (for frontend development with HMR on :5173)
# =============================================================================
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
