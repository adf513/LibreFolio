# =============================================================================
# LibreFolio Configuration
# =============================================================================
# This file is loaded by docker-compose.yml via 'env_file: .env'.
#
# PRIORITY ORDER (Docker Compose):
#   1. 'environment:' block in docker-compose.yml  ← wins (forced overrides)
#   2. 'env_file: .env'                            ← this file (user config)
#
# Docker-compose forces HOST=0.0.0.0 and LIBREFOLIO_DATA_DIR to the
# container mount path. Those overrides are necessary for Docker networking
# and volume mapping — do NOT remove them from docker-compose.yml.
# =============================================================================

# =============================================================================
# Production Server
# =============================================================================
HOST=0.0.0.0
PORT=6040
LIBREFOLIO_DATA_DIR=./backend/data/prod
# Data is stored in: <LIBREFOLIO_DATA_DIR>/sqlite/app.db, custom-uploads/, broker_reports/, logs/
# For local development, this path is relative to the project root.
# In Docker, this value is OVERRIDDEN by docker-compose.yml (→ /app/backend/data/prod-docker).
# To change where data lives on the host, edit the bind mount in docker-compose.yml:
#   ./LibreFolio-data:/app/backend/data/prod-docker  ← change left side only

# =============================================================================
# Test Server (used by ./dev.py server --test and automated tests)
# =============================================================================
TEST_PORT=6041
# Test mode is activated via: ./dev.py server --test (sets LIBREFOLIO_TEST_MODE=1)
# In test mode, data directory is ALWAYS backend/data/test/ (ignores LIBREFOLIO_DATA_DIR)

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Portfolio
# =============================================================================
PORTFOLIO_BASE_CURRENCY=EUR

# =============================================================================
# Image Preview Cache
# =============================================================================
# Max size in MB for in-memory image preview cache (per-process, default: 50)
PREVIEW_CACHE_MAX_MB=50

# =============================================================================
# Docker File Ownership
# =============================================================================
# UID/GID used at build-time and runtime so bind-mounted files belong to
# your host user instead of root.  ./dev.py docker build auto-detects these.
# For manual builds: UID=$(id -u) GID=$(id -g) docker compose build
UID=1000
GID=1000


