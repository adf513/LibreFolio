# LibreFolio Configuration

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=sqlite:///./backend/data/sqlite/app.db
TEST_DATABASE_URL=sqlite:///./backend/data/sqlite/test_app.db

# =============================================================================
# Server
# =============================================================================
PORT=8000
TEST_PORT=8001

# =============================================================================
# API
# =============================================================================
API_V1_PREFIX=/api/v1
PROJECT_NAME=LibreFolio
VERSION=0.1.0

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Portfolio
# =============================================================================
PORTFOLIO_BASE_CURRENCY=EUR

# =============================================================================
# Image Preview Cache
# =============================================================================
# Max size in MB for in-memory image preview cache (default: 50)
# Cache is per-process; with single worker this is optimal
PREVIEW_CACHE_MAX_MB=50

# =============================================================================
# CORS (for frontend development)
# =============================================================================
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
