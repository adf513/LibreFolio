{
  "name": "librefolio-frontend",
  "private": true,
  "version": "0.6.x",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build --logLevel warn",
    "build:debug": "VITE_DEBUG=true vite build --mode development --logLevel warn",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write 'src/**/*.{ts,svelte,js,css,html}' 'e2e/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,svelte,js,css,html}' 'e2e/**/*.ts'",
    "generate-api": "npx openapi-zod-client src/lib/api/openapi.json -o src/lib/api/generated.ts --export-types --with-docs --with-description",
    "i18n:audit": "python scripts/i18n-audit.py",
    "i18n:audit:xlsx": "python scripts/i18n-audit.py --format xlsx",
    "i18n:audit:md": "python scripts/i18n-audit.py --format md",
    "i18n:audit:both": "python scripts/i18n-audit.py --format both",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "test:unit:list": "vitest list",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "PWDEBUG=1 playwright test --headed",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.48.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/katex": "^0.16.8",
    "autoprefixer": "^10.4.22",
    "dotenv": "^17.2.3",
    "openapi-zod-client": "^1.18.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@embedpdf/snippet": "^2.14.3",
    "@tanstack/table-core": "^8.21.3",
    "@types/cropperjs": "^1.1.5",
    "@types/topojson-client": "^3.1.5",
    "@zodios/core": "^10.9.6",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "cheetah-grid": "^1.16.6",
    "cropperjs": "^2.1.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.8",
    "echarts": "^6.0.0",
    "graphology": "^0.26.0",
    "graphology-types": "^0.24.8",
    "katex": "^0.16.38",
    "lucide-svelte": "^0.559.0",
    "marked": "^18.0.4",
    "svelte-i18n": "^4.0.1",
    "topojson-client": "^3.1.0",
    "zod": "3.24.1"
  }
}
