[run]
source = backend/app
parallel = true
# Handle SIGTERM to save coverage data before process exits.
# Without this, SIGTERM kills the process without running atexit handlers,
# so no .coverage.<pid> file is written. Required for E2E test coverage
# where Playwright sends SIGTERM to kill the webServer after tests.
sigterm = true
# Support async/await coverage in FastAPI endpoints
# - thread: for uvicorn running in background thread
# - gevent: for asyncio event loop context switches
concurrency = thread,gevent
omit =
    */test_*
    */tests/*
    */__pycache__/*
    */site-packages/*
    */virtualenvs/*

[report]
show_missing = True
precision = 2
skip_covered = False
exclude_lines =
    # Standard exclusions
    pragma: no cover
    # Abstract methods can never be executed (only subclass overrides run)
    @abstractmethod
    # Debug-only functions (SNB provider)
    def _debug_
    # Defensive/impossible branches
    raise NotImplementedError

[html]
directory = htmlcov
title = LibreFolio Test Coverage Report

