# OpenRouter API Key for Aphra translation pipeline
# See README.md for setup instructions (OpenRouter BYOK + Google Gemini)
# Not needed when using a local backend (Ollama)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Backend (Cloud vs Local) ─────────────────────────────────
# By default, Aphra connects to OpenRouter (cloud).
# To use a LOCAL model via Ollama, set APHRA_BASE_URL:
#
#   APHRA_BASE_URL=http://localhost:11434/v1
#   APHRA_MODEL=qwen3.5-27b-claude-4.6-opus-reasoning-distilled:Q4_K_M
#
# With APHRA_BASE_URL set, OPENROUTER_API_KEY is ignored.
# See README.md § "Local Models (Ollama)" for full setup.
# APHRA_BASE_URL=http://localhost:11434/v1

# ── LLM Models ──────────────────────────────────────────────
# Aphra uses 4 roles, split into reasoning vs generation tasks:
#
#   REASONING (deeper thinking):
#     APHRA_ANALYZER  → Step 1: Analyze source text (key terms, structure)
#     APHRA_CRITIQUER → Step 4: Critique translation (defaults to APHRA_ANALYZER)
#
#   GENERATION (fast text production):
#     APHRA_WRITER    → Step 3: Translate + Step 5: Refine (defaults to APHRA_MODEL)
#     APHRA_SEARCHER  → Step 2: Web search (usually skipped)
#
# For local (Ollama), use a larger model for reasoning and smaller for generation:
#   APHRA_ANALYZER=kwangsuklee/Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-GGUF
#   APHRA_MODEL=kwangsuklee/Qwen3.5-9B-Claude-4.6-Opus-Reasoning-Distilled-GGUF
#
# For cloud (OpenRouter), a single model is usually enough:
#   APHRA_MODEL=google/gemini-2.5-flash

# Shared model for generation tasks (fallback for APHRA_WRITER)
# APHRA_MODEL=google/gemini-2.5-flash

# Reasoning model for analysis + critique (defaults to APHRA_WRITER if unset)
# APHRA_ANALYZER=google/gemini-2.5-flash

# ── Web Search ──────────────────────────────────────────────
# Aphra's Step 2 (Search) uses OpenRouter's web search plugin to look up
# context for each term found in Step 1. This adds cost ($4/1000 results)
# and is slow. For technical docs with well-known terms, it's not needed.
# Set to true only if translating content with obscure cultural references.
# NOTE: Web search only works with OpenRouter, not with local models.
APHRA_WEB_SEARCH=false
